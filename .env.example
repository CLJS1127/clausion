# ── Database ─────────────────────────────────────────
POSTGRES_DB=classpulse
POSTGRES_USER=classpulse
POSTGRES_PASSWORD=classpulse123

# ── Redis ────────────────────────────────────────────
# Redis runs with default settings (no password in dev)

# ── RabbitMQ ─────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=classpulse
RABBITMQ_PASSWORD=dev_password

# ── LiveKit ──────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=classpulse-jwt-secret-key-for-dev-only-change-in-prod
JWT_EXPIRATION_MS=86400000

# ── Spring ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Frontend ─────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_LIVEKIT_URL=ws://localhost:7880
